---
import Button from "./ui/Button.astro";
---

<form
  action="#"
  class="flex flex-col gap-2 border-2 rounded-lg border-tertiary/50 p-6 md:py-8 mx-auto w-full md:w-md"
>
  <input
    type="text"
    id="name"
    class="w-full rounded-md border-2 border-secondary pl-2 py-1.5 md:py-2 md:text-lg outline-none focus:ring-1 focus:ring-tertiary focus:border-tertiary mb-1 bg-neutral"
    placeholder="Name"
    autocomplete="name"
  />
  <input
    type="email"
    id="email"
    class="w-full rounded-md border-2 border-secondary pl-2 py-1.5 md:py-2 md:text-lg outline-none focus:ring-1 focus:ring-tertiary focus:border-tertiary mb-1 bg-neutral"
    placeholder="Email"
    autocomplete="email"
  />
  <input
    type="text"
    id="subject"
    class="w-full rounded-md border-2 border-secondary pl-2 py-1.5 md:py-2 md:text-lg outline-none focus:ring-1 focus:ring-tertiary focus:border-tertiary mb-1 bg-neutral"
    placeholder="Subject"
    autocomplete="off"
  />
  <textarea
    id="message"
    class="w-full rounded-md border-2 border-secondary pl-2 py-1.5 md:py-2 md:text-lg outline-none focus:ring-1 focus:ring-tertiary focus:border-tertiary mb-1 bg-neutral"
    placeholder="Your message..."
    autocomplete="off"
    rows="4"></textarea>
  <Button title="Send Message" bg="bg-tertiary" />
  <p
    id="contact-success"
    class="hidden rounded-md bg-tertiary/15 border border-tertiary text-tertiary px-4 py-2 text-sm mt-3"
  >
    Message submitted successfully.
  </p>
</form>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.querySelector("form");
    const successMessage = document.getElementById("contact-success");

    if (!form || !successMessage) return;

    form.addEventListener("submit", function (event) {
      event.preventDefault();
      form.reset();
      successMessage.classList.remove("hidden");
      setTimeout(() => successMessage.classList.add("hidden"), 4000);
    });
  });
</script>
