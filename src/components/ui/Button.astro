---
const { title, bg, href } = Astro.props;
---

{
  href ? (
    <a
      href={href}
      class={`inline-block text-white border border-transparent ${bg} shadow-xs font-bold leading-5 rounded-lg uppercase text-xs md:text-sm px-6 md:px-8 py-2 md:py-2.5 focus:outline-none active:scale-95 transition-transform duration-150 text-center`}
    >
      {title}
    </a>
  ) : (
    <button
      class={`text-white border border-transparent ${bg} shadow-xs font-bold leading-5 rounded-lg uppercase text-xs md:text-sm px-6 md:px-8 py-2 md:py-2.5 focus:outline-none active:scale-95 transition-transform duration-150`}
    >
      {title}
    </button>
  )
}
