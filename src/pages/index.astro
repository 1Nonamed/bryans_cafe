---
import Button from "../components/ui/Button.astro";
import Header from "../components/ui/Header.astro";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/ui/Footer.astro";
---

<Layout>
  <Header />
  <main>
    <section class="grid grid-cols-1 md:grid-cols-2 gap-8 px-6 pt-12 pb-16">
      <article class="flex flex-col gap-4 px-4">
        <header class="flex flex-col gap-2">
          <span
            class="text-sm font-medium px-2 py-1 mb-2 rounded bg-green-100 text-green-800 w-fit"
            >Open until 8:00 PM</span
          >
          <h1
            class="text-5xl text-balance font-bold tracking-wide leading-tight"
          >
            Your daily dose of <span
              class="font-serif font-semibold italic text-tertiary"
              >coffee.</span
            >
          </h1>
        </header>
        <div class="flex flex-col gap-2">
          <p class="text-lg py-2">
            Welcome back to Bryan's Cafe. Find your corner, grab a fresh brew,
            and let the world slow down for a while.
          </p>
          <p class="text-lg py-2">
            A sanctuary for coffee purists and comfort seekers. Experience our
            small-batch roasts and artisanal kitchen in the heart of the city.
          </p>
        </div>
        <div class="flex gap-4 mb-4">
          <Button title="View Menu" bg="bg-tertiary" />
          <Button title="Our Story" bg="bg-primary" />
        </div>
      </article>
      <div class="px-4">
        <img
          src="/images/hero.png"
          alt="A barista pouring latte art into a cup of coffee at Bryan's Cafe"
          class="w-full mx-auto h-auto rounded-lg object-cover"
        />
      </div>
    </section>
    <section class="bg-secondary grid grid-cols-1 md:grid-cols-2 pb-16 px-6">
      <article class="flex flex-col gap-4 px-4 pt-16">
        <header class="flex flex-col gap-2">
          <h3
            class="text-tertiary font-bold font-sans uppercase tracking-widest"
          >
            Our Heritage
          </h3>
          <h2 class="text-3xl tracking-wide leading-snug">
            Bryan's Legacy: Defined by Community.
          </h2>
        </header>
        <div class="flex flex-col gap-2">
          <p class="text-balance py-2">
            Founded in 2018, Bryan's Cafe started as a simple idea: that coffee
            should be more than a caffeine fix—it should be a ritual. We source
            our beans from single-origin farms that prioritize sustainability
            and fair wages.
          </p>
          <p class="text-balance border-b border-primary pt-2 pb-4">
            Every cup is brewed with precision, and every plate is prepared with
            seasonal ingredients from local growers. We invite you to sit back,
            unplug, and enjoy the modern hearth.
          </p>
          <div class="flex flex-col gap-1 mt-4">
            <p class="text-xl font-serif italic">
              "The best coffee is the one shared with others."
            </p>
            <p class="font-semibold">Bryan, Founder</p>
          </div>
        </div>
      </article>
      <div class="grid grid-cols-2 gap-4 py-16 px-6 max-w-[90%] mx-auto">
        <img
          src="./images/history.png"
          alt="Bryan's Cafe interior with customers enjoying coffee"
          class="w-full h-full rounded-lg object-cover"
        />
        <img
          src="/images/history_2.png"
          alt="Cozy coffee shop interior with warm lighting and rustic decor"
          class="w-full h-full rounded-lg object-cover mt-16"
        />
      </div>
    </section>
  </main>
  <Footer />
</Layout>
