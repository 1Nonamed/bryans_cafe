---
import BranchCard from "../components/BranchCard.astro";
import ContactForm from "../components/ContactForm.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main>
    <section class="bg-neutral px-6 py-12">
      <article class="text-center flex flex-col gap-4">
        <h1
          class="text-tertiary text-5xl text-balance font-bold tracking-wide leading-tight py-2"
        >
          Join Us at the Hearth
        </h1>
        <p class="text-xl text-balance py-2 tracking-wide leading-relaxed">
          Lorem ipsum, dolor sit amet consectetur adipisicing elit. Labore
          dolores accusamus totam temporibus? Nesciunt, atque!
        </p>
      </article>
    </section>
    <section class="grid px-6 pt-12 pb-8 gap-4">
      <h2
        class="text-2xl font-bold border-b-2 border-b-neutral mb-4 text-tertiary tracking-wider"
      >
        Our Branches
      </h2>
      <BranchCard
        address="76 Devonshire St Surry Hills, NSW"
        phoneNumber="02 9211 1234"
        schedule={["Mon - Fri: 6:00 - 14:30", "Sat - Sun: 7:00 - 15:00"]}
      />
      <BranchCard
        address="451 Pitt St, Haymarket Sydney, NSW"
        phoneNumber="02 9262 5678"
        schedule={["Mon - Fri: 6:00 - 16:00", "Sat - Sun: 7:00 - 15:00"]}
        variant="dark"
      />
      <BranchCard
        address="31 Alfred St, Circular Quay, NSW"
        phoneNumber="02 8971 9101"
        schedule={["Mon - Fri: 6:00 - 16:00", "Sat - Sun: 7:00 - 15:00"]}
      />
    </section>
    <section class="px-6 py-12">
      <article class="px-4 py-6 rounded-lg">
        <header class="flex flex-col gap-4 pb-6">
          <h2
            class="text-2xl font-bold border-b-2 border-b-neutral mb-4 text-tertiary tracking-wider"
          >
            Get in Touch
          </h2>
          <p class="text-lg">
            For any inquiries, please fill out the form below:
          </p>
        </header>
        <ContactForm />
      </article>
    </section>
    <section class="flex flex-col justify-center px-6 py-12">
      <h2
        class="text-2xl font-bold border-b-2 border-b-neutral mb-4 text-tertiary tracking-wider"
      >
        Our Location
      </h2>
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3312.144366398072!2d151.207719!3d-33.88593559999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12ae21aea44cd5%3A0xcf2d54666d7cca73!2s76%20Devonshire%20St%2C%20Surry%20Hills%20NSW%202010!5e0!3m2!1sen!2sau!4v1777261209615!5m2!1sen!2sau"
        height="200"
        allowfullscreen="false"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="w-full mt-4 rounded-lg"></iframe>
    </section>
  </main>
</Layout>
