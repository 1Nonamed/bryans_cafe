---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main>
    <section class="bg-neutral px-4 md:px-6 py-16 md:py-32">
      <article
        class="md:max-w-5xl mx-auto text-center flex flex-col gap-4 md:gap-6 px-2 md:px-4"
      >
        <h1
          class="text-tertiary text-5xl md:text-7xl text-balance font-bold tracking-wide leading-tight"
        >
          Privacy Policy
        </h1>
        <p
          class="text-lg lg:text-xl text-balance py-2 tracking-wide leading-relaxed"
        >
          Bryan's Cafe is committed to protecting your privacy and handling
          personal information in accordance with the Privacy Act 1988 (Cth) and
          the Australian Privacy Principles (APPs).
        </p>
      </article>
    </section>
    <section class="px-4 md:px-6 py-8 md:py-12">
      <div class="md:max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
        <article
          class="bg-secondary/10 border border-secondary/20 rounded-xl p-6"
        >
          <h2 class="text-2xl font-bold text-tertiary mb-6">What we collect</h2>
          <p class="text-base md:text-lg leading-relaxed">
            We collect only the personal information you provide directly to us,
            such as your name, email address, phone number and message when you
            contact us. We may also collect non-personal information such as
            device type, browser details and site interactions for analytics
            purposes.
          </p>
        </article>
        <article
          class="bg-secondary/10 border border-secondary/20 rounded-xl p-6"
        >
          <h2 class="text-2xl font-bold text-tertiary mb-6">
            How we use your information
          </h2>
          <p class="text-base md:text-lg leading-relaxed">
            Your personal information is used to respond to enquiries, send
            updates and manage our relationship with you. We do not use the
            information for unrelated marketing or share it outside of the
            purposes you consent to.
          </p>
        </article>
        <article
          class="bg-secondary/10 border border-secondary/20 rounded-xl p-6"
        >
          <h2 class="text-2xl font-bold text-tertiary mb-6">
            Disclosure and third parties
          </h2>
          <p class="text-base md:text-lg leading-relaxed">
            We may disclose personal information to service providers who help
            us operate the website, handle communications, and provide services.
            Third parties are only given access to information necessary to
            perform their role and must keep it secure.
          </p>
        </article>
        <article
          class="bg-secondary/10 border border-secondary/20 rounded-xl p-6"
        >
          <h2 class="text-2xl font-bold text-tertiary mb-6">
            Cookies and analytics
          </h2>
          <p class="text-base md:text-lg leading-relaxed">
            We use cookies and similar technologies to improve your experience,
            understand how the site is used and help the site run smoothly. You
            can manage cookies through your browser settings.
          </p>
        </article>
        <article
          class="bg-secondary/10 border border-secondary/20 rounded-xl p-6"
        >
          <h2 class="text-2xl font-bold text-tertiary mb-6">Security</h2>
          <p class="text-base md:text-lg leading-relaxed">
            We take reasonable steps to protect personal information from
            misuse, interference, loss, unauthorised access and disclosure.
            However, no internet transmission is completely secure and we cannot
            guarantee absolute security.
          </p>
        </article>
        <article
          class="bg-secondary/10 border border-secondary/20 rounded-xl p-6"
        >
          <h2 class="text-2xl font-bold text-tertiary mb-6">
            Access and correction
          </h2>
          <p class="text-base md:text-lg leading-relaxed">
            You may request access to or correction of any personal information
            we hold about you. Please contact us if you would like to review,
            update or remove your information.
          </p>
        </article>
        <article
          class="bg-secondary/10 border border-secondary/20 rounded-xl p-6 col-span-2"
        >
          <h2 class="text-2xl font-bold text-tertiary mb-6">Contact us</h2>
          <p class="text-base md:text-lg leading-relaxed">
            For any questions about this policy or our privacy practices, please
            get in touch through our <a
              href="/contact"
              class="text-tertiary font-semibold underline">contact page</a
            >.
          </p>
        </article>
      </div>
    </section>
  </main>
</Layout>
